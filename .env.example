# Kaka FMCG - Local Environment Variables Example
# Copy this file to '.env' or '.env.local' and replace the placeholders with your actual Supabase project credentials.

# Supabase Project URL (found in project settings -> API)
VITE_SUPABASE_URL=https://your-supabase-project.supabase.co

# Supabase Anonymous Public Key (found in project settings -> API)
VITE_SUPABASE_ANON_KEY=your-anon-public-key-here
